---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
---

<Layout title="LUNR Aerospace">
  <section class="p-8 sm:p-12 md:p-16 lg:p-24 max-w-4xl mx-auto">
    <a href="/#experience" class="text-sm text-gray-500 hover:underline">
      ← Back to Home
    </a>

    <h1 class="mt-4 text-4xl sm:text-5xl font-bold text-gray-900">
      LUNR Aerospace Corp.
    </h1>

    <p class="mt-2 text-lg text-gray-600">
      Avionics and Controls Intern | May 2026 - Present
    </p>

    <div class="mt-6 text-gray-700 leading-relaxed space-y-4">
      <p>
        UBC Rocket is a student engineering design team dedicated to the design, manufacture, and launch of suborbital rockets. As a member of the avionics group working on the team's yearly international competition rocket, I develop the electronics and firmware that allow the rocket to fly.
      </p>
    </div>

    <figure class="mt-8">
      <img
        src="/rocket5.jpg"
        alt="rocket"
        class="w-full h-auto rounded-md shadow-lg"
      />
    </figure>
    <figure class="mt-8">
      <img
        src="/rocket4.png"
        alt="rocket"
        class="w-full h-auto rounded-md shadow-lg"
      />
      <figcaption class="mt-1 text-sm text-gray-500 text-center">
            Rocket design team!
      </figcaption>
    </figure>

  </section>
</Layout>
